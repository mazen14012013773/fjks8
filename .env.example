# FreelanceHub Platform - Environment Configuration Example
# Copy this file to .env and fill in your values

# ========================================
# API Configuration
# ========================================

# API Base URL (without trailing slash)
VITE_API_BASE_URL=http://localhost:3000/api

# Environment (development, staging, production)
VITE_ENV=development

# ========================================
# Application Settings
# ========================================

# App Name
VITE_APP_NAME=FreelanceHub

# App Version
VITE_APP_VERSION=1.0.0

# Default Language
VITE_DEFAULT_LANGUAGE=ar

# ========================================
# Feature Flags
# ========================================

# Enable Demo Mode (uses mock data)
VITE_DEMO_MODE=false

# Enable Error Reporting
VITE_ERROR_REPORTING=true

# ========================================
# Logging & Debugging
# ========================================

# Enable Console Logging
VITE_DEBUG_LOG=true

# ========================================
# Payment Gateway (Optional - for future integration)
# ========================================

# Stripe Public Key (optional)
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx

# Payment Provider
# VITE_PAYMENT_PROVIDER=stripe

# ========================================
# Authentication
# ========================================

# Token Storage Key
VITE_TOKEN_KEY=authToken

# User Storage Key
VITE_USER_KEY=authUser

# Token Expiration (in hours)
VITE_TOKEN_EXPIRATION=24

# ========================================
# Third-party Services (Optional)
# ========================================

# Google Analytics ID (optional)
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXX-X

# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=https://xxxxxx@sentry.io/xxxxxx

# ========================================
# Email Configuration (Backend Only)
# ========================================

# SMTP Host
EMAIL_HOST=smtp.gmail.com

# SMTP Port
EMAIL_PORT=587

# SMTP User
EMAIL_USER=your-email@gmail.com

# SMTP Password
EMAIL_PASSWORD=your-app-password

# From Email Address
EMAIL_FROM=noreply@freelancehub.com

# ========================================
# Database Configuration (Backend Only)
# ========================================

# Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/freelancehub

# Database Name
DATABASE_NAME=freelancehub

# ========================================
# JWT Configuration (Backend Only)
# ========================================

# JWT Secret
JWT_SECRET=your-very-long-secret-key-change-in-production

# JWT Expiration
JWT_EXPIRATION=24h

# ========================================
# Session Configuration (Backend Only)
# ========================================

# Session Secret
SESSION_SECRET=your-session-secret-key

# Session Expiration (in milliseconds)
SESSION_EXPIRATION=86400000

# ========================================
# File Upload Configuration
# ========================================

# Max File Size (in MB)
MAX_FILE_SIZE=10

# Allowed File Types
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,zip

# Upload Directory
UPLOAD_DIR=./uploads

# ========================================
# Platform Configuration
# ========================================

# Platform Commission Rate (percentage)
PLATFORM_COMMISSION=10

# Minimum Project Budget
MIN_PROJECT_BUDGET=50

# Maximum Project Budget
MAX_PROJECT_BUDGET=100000

# ========================================
# Frontend URLs
# ========================================

# Home URL
VITE_HOME_URL=/

# Login URL
VITE_LOGIN_URL=/login.html

# Dashboard URL
VITE_DASHBOARD_URL=/dashboard.html

# Admin Panel URL
VITE_ADMIN_URL=/admin/dashboard.html

# ========================================
# Development Tools
# ========================================

# Enable Redux DevTools (if using Redux)
# VITE_REDUX_DEVTOOLS=true

# Mock API (for development without backend)
VITE_USE_MOCK_API=false
